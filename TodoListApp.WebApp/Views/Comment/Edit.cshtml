@model TodoListApp.WebApp.Models.CommentWebApiModel

@{
	ViewData["Title"] = "Edit Comment";
}

<div class="row justify-content-center">
	<div class="col-lg-6">
		<div class="card border-0 shadow-sm rounded-4">
			<div class="card-body p-4">
				<h3 class="fw-bold mb-4">✏️ Edit Comment</h3>

				<form asp-action="Edit" method="post">
					<input asp-for="Id" type="hidden" />
					<input asp-for="TaskId" type="hidden" />
					<input asp-for="TodoListId" type="hidden" />

					<div class="mb-4">
						<label asp-for="Text" for="Text" class="form-label fw-semibold">Comment</label>
						<textarea asp-for="Text" id="Text" class="form-control rounded-3" rows="4"></textarea>
						<span asp-validation-for="Text" class="text-danger small"></span>
					</div>

					<div class="d-flex gap-2">
						<button type="submit" class="btn btn-primary px-4">Save</button>
						<a asp-controller="Task" asp-action="Details"
						   asp-route-todoListId="@Model.TodoListId"
						   asp-route-id="@Model.TaskId"
						   class="btn btn-outline-secondary px-4">Cancel</a>
					</div>
				</form>
			</div>
		</div>
	</div>
</div>
