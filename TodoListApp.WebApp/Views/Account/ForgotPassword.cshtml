@{
	ViewData["Title"] = "Forgot Password";
	Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>Forgot Password — TodoListApp</title>
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
	<style>
		body {
			background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
			min-height: 100vh;
			display: flex;
			align-items: center;
			justify-content: center;
		}
		.auth-card {
			width: 100%;
			max-width: 420px;
			border-radius: 1.5rem;
			border: none;
			box-shadow: 0 20px 60px rgba(0,0,0,0.3);
		}
		.auth-logo {
			font-size: 2.5rem;
			font-weight: 800;
			color: #6c63ff;
		}
		.form-control {
			border-radius: 0.75rem;
			padding: 0.75rem 1rem;
			border: 1.5px solid #e2e8f0;
		}
		.form-control:focus {
			border-color: #6c63ff;
			box-shadow: 0 0 0 3px rgba(108,99,255,0.15);
		}
		.btn-auth {
			background: linear-gradient(135deg, #667eea, #764ba2);
			border: none;
			border-radius: 0.75rem;
			padding: 0.75rem;
			font-weight: 600;
			font-size: 1rem;
		}
	</style>
</head>
<body>
	<div class="card auth-card p-4 p-md-5">
		<div class="text-center mb-4">
			<div class="auth-logo">✅ TodoList</div>
			<p class="text-muted mt-1">Reset your password</p>
		</div>

		@if (!ViewData.ModelState.IsValid)
		{
			foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
			{
				<div class="alert alert-danger rounded-3 small">@error.ErrorMessage</div>
			}
		}

		@if (ViewBag.ResetLink != null)
		{
			<div class="alert alert-success rounded-3 small">
				<strong>Reset link (dev mode):</strong><br />
				<a href="@ViewBag.ResetLink" class="text-break">@ViewBag.ResetLink</a>
			</div>
		}

		<form asp-action="ForgotPassword" method="post">
			<div class="mb-4">
				<label for="email" class="form-label fw-semibold small">Email</label>
				<input type="email" id="email" name="email" class="form-control"
					   placeholder="you@example.com" />
			</div>

			<button type="submit" class="btn btn-auth btn-primary w-100 text-white">
				Send Reset Link
			</button>
		</form>

		<p class="text-center text-muted small mt-4 mb-0">
			<a asp-action="Login" class="text-decoration-none fw-semibold">← Back to Sign In</a>
		</p>
	</div>
</body>
</html>