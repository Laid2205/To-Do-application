@model TodoListApp.WebApp.Models.LoginModel

@{
	ViewData["Title"] = "Sign In";
	Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>Sign In — TodoListApp</title>
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
	<style>
		body {
			background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
			min-height: 100vh;
			display: flex;
			align-items: center;
			justify-content: center;
		}

		.auth-card {
			width: 100%;
			max-width: 420px;
			border-radius: 1.5rem;
			border: none;
			box-shadow: 0 20px 60px rgba(0,0,0,0.3);
		}

		.auth-logo {
			font-size: 2.5rem;
			font-weight: 800;
			color: #6c63ff;
			letter-spacing: -1px;
		}

		.form-control {
			border-radius: 0.75rem;
			padding: 0.75rem 1rem;
			border: 1.5px solid #e2e8f0;
		}

			.form-control:focus {
				border-color: #6c63ff;
				box-shadow: 0 0 0 3px rgba(108,99,255,0.15);
			}

		.btn-auth {
			background: linear-gradient(135deg, #667eea, #764ba2);
			border: none;
			border-radius: 0.75rem;
			padding: 0.75rem;
			font-weight: 600;
			font-size: 1rem;
			letter-spacing: 0.3px;
		}

			.btn-auth:hover {
				opacity: 0.92;
				transform: translateY(-1px);
			}
	</style>
</head>
<body>
	<div class="card auth-card p-4 p-md-5">
		<div class="text-center mb-4">
			<div class="auth-logo">✅ TodoList</div>
			<p class="text-muted mt-1">Sign in to your account</p>
		</div>

		@if (!ViewData.ModelState.IsValid)
		{
			<div class="alert alert-danger rounded-3 small">
				Invalid email or password.
			</div>
		}

		<form asp-action="Login" method="post">
			<div class="mb-3">
				<label asp-for="Email" for="Email" class="form-label fw-semibold small">Email</label>
				<input asp-for="Email" id="Email" class="form-control" placeholder="you@example.com" />
				<span asp-validation-for="Email" class="text-danger small"></span>
			</div>

			<div class="mb-4">
				<label asp-for="Password" for="Password" class="form-label fw-semibold small">Password</label>
				<input asp-for="Password" id="Password" type="password" class="form-control" placeholder="••••••••" />
				<span asp-validation-for="Password" class="text-danger small"></span>
			</div>

			<button type="submit" class="btn btn-auth btn-primary w-100 text-white">
				Sign In
			</button>
		</form>

		<p class="text-center text-muted small mt-4 mb-0">
			Don't have an account?
			<a asp-action="Register" class="text-decoration-none fw-semibold">Create one</a>
		</p>
		<p class="text-center text-muted small mt-2 mb-0">
			<a asp-action="ForgotPassword" class="text-decoration-none">Forgot password?</a>
		</p>
	</div>
</body>
</html>
