<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>@ViewData["Title"] - TodoListApp</title>
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
	<style>
		body { background-color: #f8f9fa; }
		.navbar-brand { font-weight: bold; font-size: 1.4rem; }
		.card { border-radius: 12px; }
		main { min-height: 70vh; }
	</style>
</head>
<body>
	<header>
		<nav class="navbar navbar-expand-sm navbar-dark bg-dark mb-4 shadow-sm">
			<div class="container">
				<a class="navbar-brand" asp-controller="TodoList" asp-action="Index">
					✅ TodoListApp
				</a>
				<button class="navbar-toggler" type="button" data-bs-toggle="collapse"
						data-bs-target="#navbarNav">
					<span class="navbar-toggler-icon"></span>
				</button>
				<div class="collapse navbar-collapse" id="navbarNav">
					@if (User.Identity != null && User.Identity.IsAuthenticated)
					{
						<ul class="navbar-nav me-auto">
							<li class="nav-item">
								<a class="nav-link" asp-controller="TodoList" asp-action="Index">
									My Lists
								</a>
							</li>
							<li class="nav-item">
								<a class="nav-link" asp-controller="AssignedTask" asp-action="Index">
									My Tasks
								</a>
							</li>
							<li class="nav-item">
								<a class="nav-link" asp-controller="Search" asp-action="Index">
									Search
								</a>
							</li>
							<li class="nav-item">
								<a class="nav-link" asp-controller="Tag" asp-action="Index">
									Tags
								</a>
							</li>
						</ul>
						<ul class="navbar-nav ms-auto">
							<li class="nav-item">
								<span class="nav-link text-white-50">
									👤 @User.Identity.Name
								</span>
							</li>
							<li class="nav-item">
								<form asp-controller="Account" asp-action="Logout"
									  method="post" class="d-inline">
									<button type="submit" class="btn btn-outline-light btn-sm ms-2">
										Sign Out
									</button>
								</form>
							</li>
						</ul>
					}
					else
					{
						<ul class="navbar-nav ms-auto">
							<li class="nav-item">
								<a class="nav-link" asp-controller="Account" asp-action="Login">
									Sign In
								</a>
							</li>
							<li class="nav-item">
								<a class="nav-link" asp-controller="Account" asp-action="Register">
									Register
								</a>
							</li>
						</ul>
					}
				</div>
			</div>
		</nav>
	</header>

	<div class="container">
		<main role="main">
			@RenderBody()
		</main>
	</div>

	<footer class="border-top mt-5 py-3 text-center text-muted bg-white">
		<div class="container">
			<small>TodoListApp &copy; @DateTime.Now.Year</small>
		</div>
	</footer>

	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
	@await RenderSectionAsync("Scripts", required: false)
</body>
</html>