@model TodoListApp.WebApp.Models.TodoTaskWebApiModel

@{
	ViewData["Title"] = "Create Task";
}

<div class="row justify-content-center">
	<div class="col-lg-6">
		<div class="card border-0 shadow-sm rounded-4">
			<div class="card-body p-4">
				<h3 class="fw-bold mb-4">➕ Create New Task</h3>

				<form asp-action="Create" method="post">
					<input asp-for="TodoListId" type="hidden" />

					<div class="mb-3">
						<label asp-for="Title" for="Title" class="form-label fw-semibold">Title</label>
						<input asp-for="Title" id="Title" class="form-control rounded-3"
							   placeholder="Task title..." />
						<span asp-validation-for="Title" class="text-danger small"></span>
					</div>

					<div class="mb-3">
						<label asp-for="Description" for="Description" class="form-label fw-semibold">Description</label>
						<textarea asp-for="Description" id="Description" class="form-control rounded-3" rows="3"
								  placeholder="Task description..."></textarea>
					</div>

					<div class="mb-3">
						<label asp-for="DueDate" for="DueDate" class="form-label fw-semibold">Due Date</label>
						<input asp-for="DueDate" id="DueDate" type="date" class="form-control rounded-3" />
					</div>

					<div class="mb-4">
						<label asp-for="Status" for="Status" class="form-label fw-semibold">Status</label>
						<select asp-for="Status" id="Status" class="form-select rounded-3">
							<option value="NotStarted">Not Started</option>
							<option value="InProgress">In Progress</option>
							<option value="Completed">Completed</option>
						</select>
					</div>

					<div class="d-flex gap-2">
						<button type="submit" class="btn btn-primary px-4">Create</button>
						<a asp-action="Index" asp-route-todoListId="@Model.TodoListId"
						   class="btn btn-outline-secondary px-4">Cancel</a>
					</div>
				</form>
			</div>
		</div>
	</div>
</div>
