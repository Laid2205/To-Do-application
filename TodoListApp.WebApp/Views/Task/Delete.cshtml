@model TodoListApp.WebApp.Models.TodoTaskWebApiModel

@{
	ViewData["Title"] = "Delete Task";
}

<div class="row justify-content-center">
	<div class="col-lg-5">
		<div class="card border-0 shadow-sm rounded-4">
			<div class="card-body p-4 text-center">
				<div style="font-size: 3rem;">🗑️</div>
				<h3 class="fw-bold mt-3 mb-2">Delete Task</h3>
				<p class="text-muted mb-1">Are you sure you want to delete</p>
				<p class="fw-bold fs-5 mb-4">@Model.Title</p>

				<form asp-action="Delete" method="post" class="d-flex gap-2 justify-content-center">
					<input asp-for="Id" type="hidden" />
					<input asp-for="TodoListId" type="hidden" />
					<button type="submit" class="btn btn-danger px-4">Delete</button>
					<a asp-action="Index" asp-route-todoListId="@Model.TodoListId"
					   class="btn btn-outline-secondary px-4">Cancel</a>
				</form>
			</div>
		</div>
	</div>
</div>