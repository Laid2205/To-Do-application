@model IEnumerable<TodoListApp.WebApp.Models.TodoTaskWebApiModel>

@{
	ViewData["Title"] = "Search Results";
	var searchText = ViewBag.SearchText as string;
}

<div class="d-flex justify-content-between align-items-center mb-4">
	<div>
		<h2 class="fw-bold mb-0">🔍 Results</h2>
		@if (!string.IsNullOrEmpty(searchText))
		{
			<p class="text-muted small mb-0">for "@searchText"</p>
		}
	</div>
	<a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-3">← New Search</a>
</div>

@if (!Model.Any())
{
	<div class="text-center py-5">
		<div style="font-size: 4rem;">😕</div>
		<h4 class="text-muted mt-3">No tasks found</h4>
		<a asp-action="Index" class="btn btn-primary mt-3 px-4">Try Again</a>
	</div>
}
else
{
	<div class="row row-cols-1 g-3">
		@foreach (var item in Model)
		{
			<div class="col">
				<div class="card border-0 shadow-sm rounded-4">
					<div class="card-body p-4">
						<div class="d-flex justify-content-between align-items-start">
							<div>
								<h5 class="fw-bold mb-1">@item.Title</h5>
								<p class="text-muted small mb-2">
									@(string.IsNullOrEmpty(item.Description) ? "No description" : item.Description)
								</p>
								<div class="d-flex gap-3 align-items-center">
									@switch (item.Status.ToString())
									{
										case "NotStarted":
											<span class="badge bg-secondary">Not Started</span>
											break;
										case "InProgress":
											<span class="badge bg-warning text-dark">In Progress</span>
											break;
										case "Completed":
											<span class="badge bg-success">Completed</span>
											break;
									}
									@if (item.DueDate.HasValue)
									{
										<span class="text-muted small">📅 @item.DueDate.Value.ToString("dd.MM.yyyy")</span>
									}
								</div>
							</div>
							<a asp-controller="Task" asp-action="Details"
							   asp-route-todoListId="@item.TodoListId"
							   asp-route-id="@item.Id"
							   class="btn btn-outline-primary btn-sm rounded-3">
								Details →
							</a>
						</div>
					</div>
				</div>
			</div>
		}
	</div>
}